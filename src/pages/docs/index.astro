---
import DocsLayout from "../../layouts/docs.astro";
---

<DocsLayout title="Airlock Documentation">
    <div class="space-y-8">
        <div>
            <h1 class="text-3xl md:text-4xl font-bold">Documentation</h1>
            <p class="text-muted-foreground mt-2">
                Installation guides, security practices, and reference material
                for Airlock.
            </p>
        </div>

        <!-- Search -->
        <div class="relative">
            <input
                type="text"
                id="docs-search"
                placeholder="Search documentation..."
                class="w-full rounded-xl border border-border/50 bg-muted/30 px-4 py-3 pl-10 text-sm placeholder:text-muted-foreground/50 focus:outline-none focus:ring-2 focus:ring-airlock-violet-light/50"
            />
            <svg
                class="absolute left-3 top-3.5 h-4 w-4 text-muted-foreground/50"
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2"
                stroke="currentColor"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z"
                ></path>
            </svg>
        </div>

        <!-- Installation Guides -->
        <div class="space-y-4" data-docs-category>
            <h2 class="text-xl font-semibold flex items-center gap-2">
                <span class="w-1.5 h-6 rounded-full bg-airlock-violet-light"
                ></span>
                Installation Guides
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <a
                    href="/docs/cursor"
                    class="doc-card group flex items-center gap-4 p-4 rounded-xl border border-border/50 bg-card/50 hover:shadow-md hover:border-airlock-violet-light/30 transition-all"
                    data-doc-title="Cursor Enforcer Installation"
                >
                    <img
                        src="/enforcers/cursor.png"
                        alt="Cursor"
                        class="w-10 h-10 rounded-lg"
                    />
                    <div>
                        <p
                            class="font-medium text-sm group-hover:text-airlock-violet-light transition-colors"
                        >
                            Cursor Enforcer
                        </p>
                        <p class="text-xs text-muted-foreground">
                            Install and configure Airlock for Cursor IDE
                        </p>
                    </div>
                </a>
                <a
                    href="/docs/windsurf"
                    class="doc-card group flex items-center gap-4 p-4 rounded-xl border border-border/50 bg-card/50 hover:shadow-md hover:border-airlock-violet-light/30 transition-all"
                    data-doc-title="Windsurf Enforcer Installation"
                >
                    <img
                        src="/enforcers/windsurf.png"
                        alt="Windsurf"
                        class="w-10 h-10 rounded-lg"
                    />
                    <div>
                        <p
                            class="font-medium text-sm group-hover:text-airlock-violet-light transition-colors"
                        >
                            Windsurf Enforcer
                        </p>
                        <p class="text-xs text-muted-foreground">
                            Install and configure Airlock for Windsurf IDE
                        </p>
                    </div>
                </a>
                <a
                    href="/docs/antigravity"
                    class="doc-card group flex items-center gap-4 p-4 rounded-xl border border-border/50 bg-card/50 hover:shadow-md hover:border-airlock-violet-light/30 transition-all"
                    data-doc-title="Antigravity Enforcer Installation"
                >
                    <img
                        src="/enforcers/antigravity.png"
                        alt="Antigravity"
                        class="w-10 h-10 rounded-lg"
                    />
                    <div>
                        <p
                            class="font-medium text-sm group-hover:text-airlock-violet-light transition-colors"
                        >
                            Antigravity Enforcer
                        </p>
                        <p class="text-xs text-muted-foreground">
                            Install and configure Airlock for Google Antigravity
                        </p>
                    </div>
                </a>
                <a
                    href="/docs/copilot"
                    class="doc-card group flex items-center gap-4 p-4 rounded-xl border border-border/50 bg-card/50 hover:shadow-md hover:border-airlock-violet-light/30 transition-all"
                    data-doc-title="Copilot Enforcer Installation"
                >
                    <img
                        src="/enforcers/copilot.png"
                        alt="Copilot"
                        class="w-10 h-10 rounded-lg"
                    />
                    <div>
                        <p
                            class="font-medium text-sm group-hover:text-airlock-violet-light transition-colors"
                        >
                            Copilot Enforcer
                        </p>
                        <p class="text-xs text-muted-foreground">
                            Install and configure Airlock for GitHub Copilot
                        </p>
                    </div>
                </a>
            </div>
        </div>

        <!-- CLI & Shells -->
        <div class="space-y-4" data-docs-category>
            <h2 class="text-xl font-semibold flex items-center gap-2">
                <span class="w-1.5 h-6 rounded-full bg-airlock-cyan"></span>
                CLI & Shells
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <a
                    href="/docs/cli"
                    class="doc-card group flex items-center gap-4 p-4 rounded-xl border border-border/50 bg-card/50 hover:shadow-md hover:border-airlock-cyan/30 transition-all"
                    data-doc-title="Airlock CLI User Guide"
                >
                    <div
                        class="w-10 h-10 rounded-lg bg-airlock-cyan/10 flex items-center justify-center"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="h-5 w-5 text-airlock-cyan"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="2"
                            stroke="currentColor"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                            ></path></svg
                        >
                    </div>
                    <div>
                        <p
                            class="font-medium text-sm group-hover:text-airlock-cyan transition-colors"
                        >
                            Airlock CLI
                        </p>
                        <p class="text-xs text-muted-foreground">
                            Install, sign in, pair, and use approve for sensitive commands
                        </p>
                    </div>
                </a>
                <a
                    href="/docs/shells"
                    class="doc-card group flex items-center gap-4 p-4 rounded-xl border border-border/50 bg-card/50 hover:shadow-md hover:border-airlock-cyan/30 transition-all"
                    data-doc-title="Shell Integration Bash Zsh PowerShell"
                >
                    <div
                        class="w-10 h-10 rounded-lg bg-airlock-cyan/10 flex items-center justify-center"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="h-5 w-5 text-airlock-cyan"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="2"
                            stroke="currentColor"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M4 6h16M4 12h16M4 18h7"
                            ></path></svg
                        >
                    </div>
                    <div>
                        <p
                            class="font-medium text-sm group-hover:text-airlock-cyan transition-colors"
                        >
                            Shell integration
                        </p>
                        <p class="text-xs text-muted-foreground">
                            Bash, Zsh, and PowerShell plugins — approve every command
                        </p>
                    </div>
                </a>
            </div>
        </div>

        <!-- Security & Legal -->
        <div class="space-y-4" data-docs-category>
            <h2 class="text-xl font-semibold flex items-center gap-2">
                <span class="w-1.5 h-6 rounded-full bg-airlock-cyan"></span>
                Security & Legal
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <a
                    href="/docs/data-security"
                    class="doc-card group flex items-center gap-4 p-4 rounded-xl border border-border/50 bg-card/50 hover:shadow-md hover:border-airlock-cyan/30 transition-all"
                    data-doc-title="Data Security"
                >
                    <div
                        class="w-10 h-10 rounded-lg bg-airlock-cyan/10 flex items-center justify-center"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="h-5 w-5 text-link"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="2"
                            stroke="currentColor"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"
                            ></path></svg
                        >
                    </div>
                    <div>
                        <p
                            class="font-medium text-sm group-hover:text-link transition-colors"
                        >
                            Data Security
                        </p>
                        <p class="text-xs text-muted-foreground">
                            How Airlock protects your data with cryptographic
                            guarantees
                        </p>
                    </div>
                </a>
                <a
                    href="/docs/privacy"
                    class="doc-card group flex items-center gap-4 p-4 rounded-xl border border-border/50 bg-card/50 hover:shadow-md hover:border-airlock-cyan/30 transition-all"
                    data-doc-title="Privacy Policy"
                >
                    <div
                        class="w-10 h-10 rounded-lg bg-airlock-cyan/10 flex items-center justify-center"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="h-5 w-5 text-link"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="2"
                            stroke="currentColor"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z"
                            ></path></svg
                        >
                    </div>
                    <div>
                        <p
                            class="font-medium text-sm group-hover:text-link transition-colors"
                        >
                            Privacy Policy
                        </p>
                        <p class="text-xs text-muted-foreground">
                            What data we collect and how we handle it
                        </p>
                    </div>
                </a>
            </div>
        </div>

        <!-- Reference -->
        <div class="space-y-4" data-docs-category>
            <h2 class="text-xl font-semibold flex items-center gap-2">
                <span class="w-1.5 h-6 rounded-full bg-amber-500"></span>
                Reference
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <a
                    href="https://harp-protocol.github.io/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="doc-card group flex items-center gap-4 p-4 rounded-xl border border-border/50 bg-card/50 hover:shadow-md hover:border-amber-500/30 transition-all"
                    data-doc-title="HARP Protocol Specification"
                >
                    <div
                        class="w-10 h-10 rounded-lg bg-amber-500/10 flex items-center justify-center"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="h-5 w-5 text-amber-500"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="2"
                            stroke="currentColor"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25"
                            ></path></svg
                        >
                    </div>
                    <div>
                        <p
                            class="font-medium text-sm group-hover:text-amber-500 transition-colors"
                        >
                            HARP Specification ↗
                        </p>
                        <p class="text-xs text-muted-foreground">
                            Full protocol specification with test vectors
                        </p>
                    </div>
                </a>
                <a
                    href="https://harp-protocol.github.io/blog/introducing-harp/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="doc-card group flex items-center gap-4 p-4 rounded-xl border border-border/50 bg-card/50 hover:shadow-md hover:border-amber-500/30 transition-all"
                    data-doc-title="What is HARP"
                >
                    <div
                        class="w-10 h-10 rounded-lg bg-amber-500/10 flex items-center justify-center"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="h-5 w-5 text-amber-500"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="2"
                            stroke="currentColor"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z"
                            ></path></svg
                        >
                    </div>
                    <div>
                        <p
                            class="font-medium text-sm group-hover:text-amber-500 transition-colors"
                        >
                            What is HARP? ↗
                        </p>
                        <p class="text-xs text-muted-foreground">
                            Introduction to the protocol behind Airlock
                        </p>
                    </div>
                </a>
            </div>
        </div>
    </div>

    <script>
        document
            .getElementById("docs-search")
            ?.addEventListener("input", (e) => {
                const query = (
                    e.target as HTMLInputElement
                ).value.toLowerCase();
                document.querySelectorAll(".doc-card").forEach((card) => {
                    const title =
                        card.getAttribute("data-doc-title")?.toLowerCase() ||
                        "";
                    const desc =
                        card
                            .querySelector("p:last-child")
                            ?.textContent?.toLowerCase() || "";
                    const match =
                        !query || title.includes(query) || desc.includes(query);
                    (card as HTMLElement).style.display = match ? "" : "none";
                });
                // Hide empty categories
                document
                    .querySelectorAll("[data-docs-category]")
                    .forEach((cat) => {
                        const visibleCards = cat.querySelectorAll(
                            '.doc-card:not([style*="display: none"])',
                        );
                        (cat as HTMLElement).style.display =
                            visibleCards.length > 0 ? "" : "none";
                    });
            });
    </script>
</DocsLayout>
