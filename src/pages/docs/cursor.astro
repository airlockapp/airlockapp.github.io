---
import DocsLayout from "../../layouts/docs.astro";
---

<DocsLayout title="Install Airlock Cursor Enforcer">
    <div class="space-y-8">
        <div class="flex items-center gap-4">
            <img
                src="/enforcers/cursor.png"
                alt="Airlock Cursor Enforcer"
                class="w-16 h-16 rounded-xl"
            />
            <div>
                <h1 class="text-3xl md:text-4xl font-bold">
                    Airlock Cursor Enforcer
                </h1>
                <p class="text-muted-foreground mt-1">
                    Human approval for AI actions in Cursor
                </p>
            </div>
        </div>

        <div class="flex flex-wrap gap-3 mt-4">
            <a
                href="https://marketplace.visualstudio.com/items?itemName=out-of-band-systems.airlock-cursor-enforcer"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-border/50 bg-muted/30 text-sm font-medium text-foreground hover:bg-muted/60 transition-colors"
            >
                <img
                    src="/enforcers/vscode-marketplace.svg"
                    alt=""
                    class="w-4 h-4"
                    onerror="this.style.display='none'"
                />
                VS Code Marketplace
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-3.5 h-3.5 text-muted-foreground"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path
                        d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"
                    ></path><polyline points="15 3 21 3 21 9"></polyline><line
                        x1="10"
                        y1="14"
                        x2="21"
                        y2="3"></line></svg
                >
            </a>
            <a
                href="https://open-vsx.org/extension/out-of-band-systems/airlock-cursor-enforcer"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-border/50 bg-muted/30 text-sm font-medium text-foreground hover:bg-muted/60 transition-colors"
            >
                Open VSX Registry
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-3.5 h-3.5 text-muted-foreground"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path
                        d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"
                    ></path><polyline points="15 3 21 3 21 9"></polyline><line
                        x1="10"
                        y1="14"
                        x2="21"
                        y2="3"></line></svg
                >
            </a>
            <a
                href="https://github.com/airlockapp/extensions/tree/main/src/airlock-cursor-enforcer"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-border/50 bg-muted/30 text-sm font-medium text-foreground hover:bg-muted/60 transition-colors"
            >
                GitHub
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-3.5 h-3.5 text-muted-foreground"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path
                        d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"
                    ></path><polyline points="15 3 21 3 21 9"></polyline><line
                        x1="10"
                        y1="14"
                        x2="21"
                        y2="3"></line></svg
                >
            </a>
        </div>

        <div class="prose dark:prose-invert max-w-none">
            <h2 class="text-xl font-semibold mt-8 mb-4">Prerequisites</h2>
            <ul class="space-y-2 text-muted-foreground">
                <li class="flex items-start gap-2">
                    <span class="text-link mt-1">•</span>
                    <span
                        ><a
                            href="https://www.cursor.com/"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-link hover:underline">Cursor</a
                        > IDE installed</span
                    >
                </li>
                <li class="flex items-start gap-2">
                    <span class="text-link mt-1">•</span>
                    <span>An Airlock account</span>
                </li>
                <li class="flex items-start gap-2">
                    <span class="text-link mt-1">•</span>
                    <span
                        >The Airlock Mobile Approver app installed on your phone
                        (Android or iOS)</span
                    >
                </li>
            </ul>

            <h2 class="text-xl font-semibold mt-8 mb-4">Getting Started</h2>
            <ol class="space-y-4 text-muted-foreground">
                <li class="flex items-start gap-3">
                    <span
                        class="flex-shrink-0 w-7 h-7 rounded-full bg-airlock-violet/20 text-airlock-violet-light text-sm font-bold flex items-center justify-center"
                        >1</span
                    >
                    <div>
                        <p class="font-medium text-foreground">
                            Install the Extension
                        </p>
                        <p class="text-sm mt-1">
                            In Cursor, open the Extensions panel (<code
                                class="px-1.5 py-0.5 rounded bg-muted text-xs font-mono"
                                >Ctrl+Shift+X</code
                            > / <code
                                class="px-1.5 py-0.5 rounded bg-muted text-xs font-mono"
                                >Cmd+Shift+X</code
                            >), search for <code
                                class="px-1.5 py-0.5 rounded bg-muted text-xs font-mono"
                                >Airlock Enforcer</code
                            >, and install <strong
                                >Airlock Cursor Enforcer</strong
                            >.
                        </p>
                    </div>
                </li>
                <li class="flex items-start gap-3">
                    <span
                        class="flex-shrink-0 w-7 h-7 rounded-full bg-airlock-violet/20 text-airlock-violet-light text-sm font-bold flex items-center justify-center"
                        >2</span
                    >
                    <div>
                        <p class="font-medium text-foreground">Sign In</p>
                        <p class="text-sm mt-1">
                            Open the Command Palette (<code
                                class="px-1.5 py-0.5 rounded bg-muted text-xs font-mono"
                                >Ctrl+Shift+P</code
                            > / <code
                                class="px-1.5 py-0.5 rounded bg-muted text-xs font-mono"
                                >Cmd+Shift+P</code
                            >) and run <code
                                class="px-1.5 py-0.5 rounded bg-muted text-xs font-mono"
                                >Airlock: Sign In</code
                            >. Authenticate with your Airlock account.
                        </p>
                    </div>
                </li>
                <li class="flex items-start gap-3">
                    <span
                        class="flex-shrink-0 w-7 h-7 rounded-full bg-airlock-violet/20 text-airlock-violet-light text-sm font-bold flex items-center justify-center"
                        >3</span
                    >
                    <div>
                        <p class="font-medium text-foreground">
                            Pair with Mobile App
                        </p>
                        <p class="text-sm mt-1">
                            Run <code
                                class="px-1.5 py-0.5 rounded bg-muted text-xs font-mono"
                                >Airlock: Start Mobile Pairing</code
                            > from the Command Palette. A QR code will be displayed.
                            On the Airlock Mobile Approver app, go to <strong
                                >Settings → Pair Another Workspace</strong
                            >, scan the QR code or enter the pairing code
                            manually.
                        </p>
                    </div>
                </li>
                <li class="flex items-start gap-3">
                    <span
                        class="flex-shrink-0 w-7 h-7 rounded-full bg-airlock-violet/20 text-airlock-violet-light text-sm font-bold flex items-center justify-center"
                        >4</span
                    >
                    <div>
                        <p class="font-medium text-foreground">
                            Enable Auto Mode
                        </p>
                        <p class="text-sm mt-1">
                            Run <code
                                class="px-1.5 py-0.5 rounded bg-muted text-xs font-mono"
                                >Airlock: Enable Auto Mode</code
                            > to start intercepting AI actions. All agent commands
                            will now require your mobile approval.
                        </p>
                    </div>
                </li>
            </ol>

            <h2 class="text-xl font-semibold mt-8 mb-4">Extension Commands</h2>
            <table class="w-full text-sm border-collapse">
                <thead>
                    <tr class="border-b border-border/50">
                        <th class="text-left py-2 font-medium">Command</th>
                        <th class="text-left py-2 font-medium">Description</th>
                    </tr>
                </thead>
                <tbody class="text-muted-foreground">
                    <tr class="border-b border-border/30"
                        ><td class="py-2"
                            ><code class="rounded bg-muted px-1"
                                >Airlock: Sign In</code
                            ></td
                        ><td class="py-2">Authenticate with the Gateway</td></tr
                    >
                    <tr class="border-b border-border/30"
                        ><td class="py-2"
                            ><code class="rounded bg-muted px-1"
                                >Airlock: Sign Out</code
                            ></td
                        ><td class="py-2">Clear authentication</td></tr
                    >
                    <tr class="border-b border-border/30"
                        ><td class="py-2"
                            ><code class="rounded bg-muted px-1"
                                >Airlock: Start Mobile Pairing</code
                            ></td
                        ><td class="py-2"
                            >Pair with the Airlock mobile app (QR code)</td
                        ></tr
                    >
                    <tr class="border-b border-border/30"
                        ><td class="py-2"
                            ><code class="rounded bg-muted px-1"
                                >Airlock: Unpair Mobile Approver</code
                            ></td
                        ><td class="py-2">Remove paired device</td></tr
                    >
                    <tr class="border-b border-border/30"
                        ><td class="py-2"
                            ><code class="rounded bg-muted px-1"
                                >Airlock: Enable Auto Mode</code
                            ></td
                        ><td class="py-2">Start automatic approval gating</td
                        ></tr
                    >
                    <tr class="border-b border-border/30"
                        ><td class="py-2"
                            ><code class="rounded bg-muted px-1"
                                >Airlock: Disable Auto Mode</code
                            ></td
                        ><td class="py-2">Stop gating</td></tr
                    >
                    <tr class="border-b border-border/30"
                        ><td class="py-2"
                            ><code class="rounded bg-muted px-1"
                                >Airlock: Show Status</code
                            ></td
                        ><td class="py-2"
                            >Show current endpoint, enforcer ID, pairing state</td
                        ></tr
                    >
                </tbody>
            </table>

            <h2 class="text-xl font-semibold mt-8 mb-4">How It Works</h2>
            <p class="text-muted-foreground">
                Once installed, the Airlock Cursor Enforcer intercepts all
                AI-generated terminal commands and file mutations. Each action
                is encrypted with AES-256-GCM and submitted to the Gateway. Your
                Mobile Approver receives a push notification — you review the
                action and sign your decision with Ed25519. The enforcer
                verifies the signature locally before allowing execution.
            </p>

            <div
                class="mt-8 p-4 rounded-xl border border-border/50 bg-muted/30"
            >
                <p class="text-sm text-muted-foreground">
                    <strong class="text-foreground">Security model:</strong> The enforcer
                    operates in fail-closed mode. If the gateway is unreachable, the
                    signature is invalid, or the request times out — the action is
                    blocked. No exceptions.
                </p>
            </div>
        </div>

        <div class="mt-8 flex gap-4">
            <a href="/docs" class="text-sm text-link hover:underline"
                >← All Docs</a
            >
            <a href="/" class="text-sm text-muted-foreground hover:underline"
                >Back to Airlock</a
            >
        </div>
    </div>
</DocsLayout>
